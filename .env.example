# Public site URL (used to build absolute links + redirect targets)
NEXT_PUBLIC_SITE_URL=https://nhanga.example.com

# Upstash Redis — persistence layer
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Web Push (VAPID) — generate via `npx web-push generate-vapid-keys`
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Cron auth — random 32-byte hex; required for /api/cron/* endpoints
# Vercel Cron sends this in the Authorization header automatically
CRON_SECRET=

# Google Gemini — free API key for lyrics translation
# Get one at https://aistudio.google.com/apikey (no credit card required)
GOOGLE_GENERATIVE_AI_API_KEY=

# Translator model (optional; defaults to gemini-2.5-flash-lite — works on the free tier).
# Avoid gemini-2.0-flash: many AI Studio keys have a free-tier limit of 0 on it.
# Pick another from: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-flash-latest.
AI_TRANSLATOR_MODEL=gemini-2.5-flash-lite

# Rate limiting (requests per minute per IP on POST endpoints)
RATE_LIMIT_PER_MINUTE=20
